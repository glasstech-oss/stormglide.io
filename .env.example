# Copy this file to .env and fill in your values.
# Stormglide environment variables

# ─── Supabase ──────────────────────────────────────────────
# Create a project at https://supabase.com, then grab these from:
# Project Settings → API → Project URL & anon/public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Without these the app falls back to localStorage automatically.
# Set them to unlock: real database, secure admin auth, and email notifications.
